<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFA">

    <!-- CENTER CONTENT -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- LOGO -->
        <ImageView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/screen" />

        <!-- APP NAME -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="GrowSave"
            android:textColor="#0AA06E"
            android:textSize="34sp"
            android:textStyle="bold" />

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Neighborhood financial management\ntransparent and simple."
            android:textAlignment="center"
            android:textColor="#6F6F6F"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- BOTTOM AREA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="30dp">

        <!-- LOADING -->
        <ProgressBar
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:indeterminateTint="#0AA06E" />

        <!-- TEXT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Initializing Secure Access..."
            android:textColor="#A0A0A0"
            android:textSize="12sp" />

    </LinearLayout>

</RelativeLayout>