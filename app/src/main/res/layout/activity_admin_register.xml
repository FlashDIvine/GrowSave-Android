<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F7F9"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOP BAR -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="16dp">

                <!-- LOGO -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/screen" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="GrowSave"
                        android:textColor="#198754"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- CLOSE -->
                <ImageView
                    android:id="@+id/btnClose"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_close" />

            </RelativeLayout>

            <!-- CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="20dp">

                    <!-- TITLE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="24dp"
                        android:text="Buat Akun Baru"
                        android:textColor="#222222"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <!-- SUBTITLE -->
                    <TextView
                        android:layout_width="250dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:lineSpacingExtra="2dp"
                        android:text="Lengkapi data diri Anda untuk memulai pengelolaan lingkungan yang lebih transparan."
                        android:textColor="#777777"
                        android:textSize="13sp" />

                    <!-- TAB -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="22dp"
                        android:orientation="horizontal">

                        <!-- WARGA -->
                        <LinearLayout
                            android:id="@+id/tabWarga"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Warga"
                                android:textColor="#888888"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <!-- ADMIN -->
                        <LinearLayout
                            android:id="@+id/tabAdmin"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Admin"
                                android:textColor="#198754"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- LINE -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E5E5E5" />

                    <!-- INDICATOR -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:orientation="horizontal">

                        <!-- LEFT -->
                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent" />

                        <!-- RIGHT -->
                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="#198754" />

                    </LinearLayout>

                    <!-- INFO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="18dp"
                        android:layout_marginTop="18dp"
                        android:background="#EAF8F0"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginTop="2dp"
                            android:src="@drawable/ic_info" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:lineSpacingExtra="2dp"
                            android:text="Pendaftaran admin memerlukan persetujuan sistem sebelum dapat mengakses dashboard pengelolaan."
                            android:textColor="#5B6B63"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- FORM -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="18dp">

                        <!-- NAMA -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Nama Lengkap"
                            android:textColor="#555555"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:boxBackgroundColor="#F5F6F7"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxStrokeWidth="0dp"
                            app:hintEnabled="false"
                            app:startIconDrawable="@drawable/ic_person"
                            app:startIconTint="#9E9E9E">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="Contoh: Budi Santoso"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#222222"
                                android:textSize="12sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- EMAIL -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Alamat Email"
                            android:textColor="#555555"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:boxBackgroundColor="#F5F6F7"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxStrokeWidth="0dp"
                            app:hintEnabled="false"
                            app:startIconDrawable="@drawable/ic_email"
                            app:startIconTint="#9E9E9E">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="nama@email.com"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#222222"
                                android:textSize="12sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- PASSWORD -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Kata Sandi"
                            android:textColor="#555555"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:boxBackgroundColor="#F5F6F7"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxStrokeWidth="0dp"
                            app:hintEnabled="false"
                            app:startIconDrawable="@drawable/ic_lock"
                            app:startIconTint="#9E9E9E"
                            app:endIconMode="password_toggle">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="••••••••"
                                android:inputType="textPassword"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#222222"
                                android:textSize="12sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- CONFIRM PASSWORD -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Konfirmasi Kata Sandi"
                            android:textColor="#555555"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:boxBackgroundColor="#F5F6F7"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxStrokeWidth="0dp"
                            app:hintEnabled="false"
                            app:startIconDrawable="@drawable/ic_lock"
                            app:startIconTint="#9E9E9E"
                            app:endIconMode="password_toggle">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etConfirmPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="••••••••"
                                android:inputType="textPassword"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#222222"
                                android:textSize="12sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- KODE ADMIN -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Kode Admin"
                            android:textColor="#555555"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:boxBackgroundColor="#F5F6F7"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxStrokeWidth="0dp"
                            app:hintEnabled="false"
                            app:startIconDrawable="@drawable/ic_key"
                            app:startIconTint="#9E9E9E">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAdminCode"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="Masukkan Kode Admin"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp"
                                android:textColor="#222222"
                                android:textSize="12sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- BUTTON -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRegister"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="24dp"
                            android:text="Daftar Sebagai Admin"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            app:backgroundTint="#04764E"
                            app:cornerRadius="10dp" />

                        <!-- LOGIN -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sudah punya akun? "
                                android:textColor="#999999"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvLogin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Masuk"
                                android:textColor="#327BFF"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>