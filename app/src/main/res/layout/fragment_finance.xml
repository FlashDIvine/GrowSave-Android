<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ==================== HEADER ==================== -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/btn_menu"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menu"
                app:tint="#0D7B43" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/btn_menu"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:text="GrowSave"
                android:textColor="#0D7B43"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_bell"
                    android:contentDescription="Notifikasi"
                    app:tint="#1F2937" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_avatar_placeholder"
                    android:contentDescription="Profil"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent" />
            </LinearLayout>
        </RelativeLayout>

        <!-- ==================== CONTENT AREA ==================== -->

        <!-- Hero Card: Total Tagihan Belum Bayar -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHeroUnpaid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_card_gradient"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_centerVertical="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL TAGIHAN BELUM BAYAR"
                        android:textColor="#E6F4EA"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvTotalUnpaidBills"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Rp 0"
                        android:textColor="@android:color/white"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvUnpaidSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Dari 0 tagihan aktif"
                        android:textColor="#C6F6D5"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Semi-transparent icon on the right -->
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:alpha="0.25"
                    android:src="@drawable/ic_receipt"
                    android:contentDescription="Receipt Icon"
                    app:tint="@android:color/white" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ==================== STATS GRID ==================== -->

        <!-- Row 1: Jumlah Tagihan + Tagihan Aktif -->
        <LinearLayout
            android:id="@+id/layoutStatsRow1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Card: Jumlah Tagihan -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTotalBills"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle_blue">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_receipt"
                            android:contentDescription="Jumlah Tagihan"
                            app:tint="#1E40AF" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvTotalBillsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0"
                        android:textColor="#1E3A8A"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Jumlah Tagihan"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Tagihan Aktif -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActiveBills"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle_amber">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_clock_outline"
                            android:contentDescription="Tagihan Aktif"
                            app:tint="#92400E" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvActiveBillsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0"
                        android:textColor="#92400E"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Tagihan Aktif"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Row 2: Tagihan Lunas (full width) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPaidBills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle_green">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="Tagihan Lunas"
                        app:tint="#065F46" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tagihan Lunas"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvPaidBillsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="0 tagihan"
                        android:textColor="#065F46"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    android:contentDescription="Lihat detail"
                    app:tint="#9CA3AF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ==================== SECTION DIVIDER ==================== -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:background="#E5E7EB" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Daftar Tagihan"
            android:textColor="#1F2937"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                android:contentDescription="Cari"
                app:tint="#9CA3AF" />

            <EditText
                android:id="@+id/etSearchBill"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:background="@android:color/transparent"
                android:hint="Cari tagihan..."
                android:textColorHint="#9CA3AF"
                android:textSize="14sp"
                android:inputType="text"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Create Bill Button (Admin Only) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_bill"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#0D7B43"
            android:text="➕  Buat Tagihan Baru"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:cornerRadius="14dp" />

        <!-- ==================== LOADING STATE ==================== -->
        <LinearLayout
            android:id="@+id/layoutLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="#0D7B43" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Memuat data tagihan..."
                android:textColor="#6B7280"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ==================== EMPTY STATE ==================== -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_receipt"
                android:contentDescription="Tidak ada tagihan"
                android:alpha="0.3"
                app:tint="#9CA3AF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Belum Ada Tagihan"
                android:textColor="#374151"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tagihan yang dibuat akan muncul di sini"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- ==================== ERROR STATE ==================== -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"
            android:background="@drawable/bg_error_card">

            <TextView
                android:id="@+id/tvErrorMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gagal memuat data"
                android:textColor="#DC2626"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Periksa koneksi internet Anda"
                android:textColor="#EF4444"
                android:textSize="12sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/btnRetry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_retry_button"
                android:paddingHorizontal="24dp"
                android:paddingVertical="10dp"
                android:text="Coba Lagi"
                android:textColor="#EF4444"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ==================== BILL LIST ==================== -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFinance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>