<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FA"
    android:padding="24dp">

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_arrow_back"
        app:tint="#0F172A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Buat Tagihan Baru"
        android:textColor="#0F172A"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toEndOf="@id/btn_back" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Judul Tagihan -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama / Judul Tagihan"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_bill_title"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Contoh: Perbaikan Gerbang RT"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:inputType="text"/>

                <!-- Deskripsi Tagihan -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deskripsi / Keterangan"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp" />

                <EditText
                    android:id="@+id/et_bill_description"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="6dp"
                    android:gravity="top|start"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Jelaskan detail program iuran ini..."
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:inputType="textMultiLine"/>

                <!-- Target Dana Total -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target Dana Total (Rupiah)"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp" />

                <EditText
                    android:id="@+id/et_bill_target_amount"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Contoh: 5000000"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:inputType="number"/>

                <!-- Iuran Wajib per Warga -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Iuran Wajib Per Warga (Rupiah)"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp" />

                <EditText
                    android:id="@+id/et_bill_amount"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Contoh: 50000"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:inputType="number"/>

                <!-- Tanggal Jatuh Tempo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tanggal Jatuh Tempo"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp" />

                <EditText
                    android:id="@+id/et_bill_due_date"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:hint="Pilih tanggal jatuh tempo"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    android:focusable="false"
                    android:clickable="true"/>

                <!-- Action Button -->
                <Button
                    android:id="@+id/btn_save"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="20dp"
                    android:text="Simpan Tagihan"
                    android:backgroundTint="#0D7B43"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
